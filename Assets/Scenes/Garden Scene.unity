  m_Name: 
  m_EditorClassIdentifier: '::'
  introDialougeLines:
  - Ohohoh, hello traveler! I've never seen you before!
  - Welcome to my garden, full of beauty and whimsy!
  - Ohohoh, you're decorating a friend's house? I don't know them...
  - ... but I do have some things lying around that you could take!
  - How's about [items]?
  reminderDialougeLines:
  - I have [items] lying around somewhere you can take!
  closingDialougeLines:
  - Splendid, splendid! Excellent picks! The bee taxi has opened now, toodaloo~
  goAwayDialouge:
  - The bee taxi is open, go get a lift.
  requiredItemsForUnlock:
  - '[items]'
