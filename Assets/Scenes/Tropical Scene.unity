--- !u!114 &4594198087079484986
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2593858590744731567}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7c054fe7c05c84b4095755f286595728, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  introDialougeLines:
  - Yo dude, it's, like, me, Luke!
  - Y'know, like, the totally legendary surfer Luke Warmwater?
  - Like dude today I rode the most GNARLY wave
  - and I saw some free stuff washed up along the shoreline
  - Go find a coconut, a sea shell and a starfish and come back to me.
  reminderDialougeLines:
  - Yo dude, you still don't have all the stuff bro
  - Go find a coconut, a sea shell and a starfish and come back to me 'kay dude.
  closingDialougeLines:
  - Yo those are some radical finds my dude!
  - Best of luck out there bro, the bee taxi is to your left, or right..?
  - 'Hey, I dont know man I feel like I am walking in circles some days. '
  goAwayDialouge:
  - The bee taxi is waiting bruh. Go left or right you'll see it eventually.
  requiredItemsForUnlock:
  - Coconut
  - Shell
  - Starfish
  chatObject: {fileID: 7892799001348104329}
  exclMark: {fileID: 6599473843743862720}
